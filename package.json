{
  "name": "claude-usage-statusbar",
  "displayName": "Claude Usage Statusbar",
  "description": "Zeigt die Claude Code Rate-Limit-Nutzung (Session & Weekly) in der VS Code Statusleiste.",
  "version": "0.1.0",
  "publisher": "dipser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dipser/claude-usage-statusbar"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "anthropic", "usage", "rate limit", "statusbar"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsage.info",
        "title": "Claude Usage: Info"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
